# Most features are optional — the site works without keys (they degrade
# gracefully). The blog CMS, lead email + lead storage need the keys below.

# AI tools (instant audit + ad-copy generator) — written by Claude when set
ANTHROPIC_API_KEY=

# Contact + lead form email delivery (Resend)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=          # must be on a Resend-verified domain

# Cloudflare Turnstile spam protection (optional)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Supabase — blog CMS + lead storage (run supabase/schema.sql once)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Blog CMS admin login (used at /admin)
ADMIN_PASSWORD=
