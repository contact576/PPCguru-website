# Most features are optional — the site works without keys (they degrade
# gracefully). The blog CMS, lead email + lead storage need the keys below.

# AI tools (instant audit + ad-copy generator) — written by Claude when set
ANTHROPIC_API_KEY=

# Contact + lead form email delivery (Resend)
RESEND_API_KEY=
# Comma-separated list of recipients. Leave blank to use the built-in team
# default: contact@ppcguru.ca, sales@ppcguru.ca, marketing@ppcguru.ca
CONTACT_TO_EMAIL=contact@ppcguru.ca,sales@ppcguru.ca,marketing@ppcguru.ca
CONTACT_FROM_EMAIL=          # must be on a Resend-verified domain

# Cloudflare Turnstile — the "I'm not a robot" check on EVERY form.
# Free, unlimited. Get both keys at: https://dash.cloudflare.com → Turnstile →
# Add widget (Domains: ppcguru.ca + *.vercel.app, Widget mode: Managed).
# Set BOTH or neither: with only one set the widget never renders and the check
# is skipped (see lib/turnstile.ts). Once both are set the check is enforced —
# a missing or invalid token is rejected.
# Without them, forms still fall back to lib/spam-filter.ts heuristics.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Supabase — blog CMS + lead storage (run supabase/schema.sql once)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Blog CMS admin login (used at /admin)
ADMIN_PASSWORD=

# IndexNow — instant crawl pings to Bing/Yandex on blog publish (optional).
# Any random 8–128 char hex string; it's also served at /indexnow-key.txt.
# Leave blank to disable pinging. (Google doesn't use IndexNow — see lib/indexnow.ts.)
INDEXNOW_KEY=

# Analytics — both have working defaults baked into
# components/analytics/third-party.tsx, so only set these to point a
# staging/preview deploy at a different container/project (or blank them to
# disable tracking there).
NEXT_PUBLIC_GTM_ID=GTM-NRX9BRWF
NEXT_PUBLIC_CLARITY_ID=xpxkvrbt7j
